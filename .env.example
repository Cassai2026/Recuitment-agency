# =============================================================================
# Lilieth Sovereign Network — Environment Variables
# Copy this file to .env and fill in real values before starting the stack
# NEVER commit your .env file to version control
# =============================================================================

# PostgreSQL
POSTGRES_DB=lilieth_hub
POSTGRES_USER=lilieth
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# FastAPI / Lilieth Orchestrator
SECRET_KEY=CHANGE_ME_at_least_32_random_chars
ENVIRONMENT=production

# Comma-separated list of allowed CORS origins (leave empty to disable CORS)
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# Module 1 — The Intake: Twilio WhatsApp webhook
# =============================================================================
TWILIO_ACCOUNT_SID=CHANGE_ME_twilio_account_sid
TWILIO_AUTH_TOKEN=CHANGE_ME_twilio_auth_token
# Your Twilio WhatsApp sender number (Sandbox or approved number)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# =============================================================================
# Module 2 — The Optical Shield: Compliance card OCR
# =============================================================================
# Path to your GCP service-account key file (JSON).
# Leave blank to use Tesseract fallback (local OCR, no cloud required).
GOOGLE_APPLICATION_CREDENTIALS=
# Set to "1" to force Tesseract even when GCP credentials are present
USE_TESSERACT_FALLBACK=0

# =============================================================================
# Module 4 — The Forensic RAMS: PDF output directory
# =============================================================================
# Absolute path where generated RAMS PDFs are saved.
# In Docker this volume is mounted at /rams_vault.
RAMS_VAULT_PATH=/rams_vault
