# =============================================================================
# Lilieth Sovereign Network — Environment Variables
# Copy this file to .env and fill in real values before starting the stack
# NEVER commit your .env file to version control
# =============================================================================

# PostgreSQL
POSTGRES_DB=lilieth_hub
POSTGRES_USER=lilieth
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# FastAPI / Lilieth Orchestrator
SECRET_KEY=CHANGE_ME_at_least_32_random_chars
ENVIRONMENT=production

# Comma-separated list of allowed CORS origins (leave empty to disable CORS)
# Example: CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=
